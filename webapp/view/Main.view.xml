<mvc:View
  controllerName="de.marianzeis.controller.Main"
  displayBlock="true"
  xmlns="sap.m"
  xmlns:mvc="sap.ui.core.mvc"
  xmlns:app="http://schemas.sap.com/sapui5/extension/sap.ui.core.CustomData/1"
  xmlns:core="sap.ui.core">

  <Page title="Marian Zeis — SAP AI, UI5/Fiori &amp; ABAP/RAP" showHeader="true">

    <content>
      <!-- Hero Section -->
      <VBox class="heroSection">
        <!-- Company Name -->
        <Title text="IT Consulting Marian Zeis" class="sapUiSmallMarginBottom companyNameTitle"/>

        <!-- Personal Summary -->
        <HBox class="heroMainRow" wrap="Wrap" alignItems="Start">
          <Avatar
            src="/data/profile.jpg"
            displaySize="XL"
            displayShape="Square"
            class="heroAvatar"/>

          <VBox class="heroProfileBlock">
            <Title text="Marian Zeis" level="H2" class="heroProfileTitle"/>
            <Text text="Independent SAP Developer and Consultant" class="heroSubTitle"/>

            <HBox class="heroFocusTags" wrap="Wrap">
              <Text text="AI Development in SAP" class="heroFocusTag"/>
              <Text text="UI5 / Fiori Elements" class="heroFocusTag"/>
              <Text text="ABAP / RAP Development" class="heroFocusTag"/>
            </HBox>

            <Text
              text="I build enterprise-ready SAP solutions that combine practical AI workflows, modern UI5 frontends, and robust ABAP/RAP backends."
              class="heroSummaryText"/>

            <HBox class="heroMetaGroup" wrap="Wrap">
              <Text text="Mainleus, Bavaria, Germany" class="heroMetaPill"/>
              <Text text="DSAG AG UI-Technologies Speaker" class="heroMetaPill"/>
            </HBox>
          </VBox>
        </HBox>
      </VBox>

      <!-- Contact Info -->
      <List headerText="Contact Information" items="{profileData>/contactInfo}">
        <CustomListItem class="sapMListItem reducedHeight clickableItem contactItem">
          <FlexBox width="100%" direction="Column" class="sapUiTinyMarginBeginEnd reducedHeight">
            <Link
              text="{profileData>title}"
              href="{profileData>link}"
              target="_blank"
              class="sapMSLITitle fullSizeLink contactTitleLink" />
            <Text
              text="{profileData>description}"
              class="sapMSLIDescription"
              visible="{= !!${profileData>description} }" />
          </FlexBox>
        </CustomListItem>
      </List>

      <!-- Featured Projects -->
      <List headerText="Featured Projects" items="{profileData>/projects}">
        <StandardListItem
          title="{profileData>title}"
          description="{profileData>description}"
          type="{profileData>type}"
          press="onNavigateToProfile"
          class="projectCard"
          app:link="{profileData>link}"/>
      </List>

      <!-- Blog Posts -->
      <List headerText="Latest Blog Posts" items="{profileData>/blogPosts}">
        <StandardListItem
          title="{profileData>title}"
          description="{profileData>date}"
          type="Navigation"
          press="onNavigateToProfile"
          class="blogPostCard"
          app:link="{profileData>link}"/>
      </List>

      <!-- Professional Experience -->
      <List headerText="Professional Experience" items="{profileData>/experience}">
        <StandardListItem
          title="{profileData>title}"
          description="{profileData>description}"
          class="experienceCard"/>
      </List>

      <!-- Presentations -->
      <List headerText="Presentations &amp; Talks" items="{profileData>/presentations}">
        <CustomListItem class="customListItem">
          <VBox>
            <Title text="{profileData>title}" level="H3"/>
            <HBox items="{path: 'profileData>links', templateShareable:false}">
              <Link
                text="{profileData>text}"
                href="{profileData>url}"
                target="_blank"
                class="sapUiTinyMarginEnd presentationLink"/>
            </HBox>
          </VBox>
        </CustomListItem>
      </List>

      <!-- Videos -->
      <List headerText="Video Content" items="{profileData>/videos}">
        <StandardListItem
          title="{profileData>title}"
          type="Navigation"
          press="onNavigateToProfile"
          app:link="{profileData>link}"/>
      </List>

      <!-- Footer -->
      <VBox class="sapUiMediumMarginTop" alignItems="Center">
        <Link text="Impressum / Legal Notice" press="onNavigateToImpressum" class="impressumLink"/>
        <Text text="© 2026 Marian Zeis" class="sapUiTinyMarginTop"/>
      </VBox>
    </content>
  </Page>

</mvc:View>
